  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "ai",
    "design"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshghal/figma-agent-bridge.git",
    "directory": "server"
  },
  "homepage": "https://github.com/joshghal/figma-agent-bridge#readme",
  "bugs": {
    "url": "https://github.com/joshghal/figma-agent-bridge/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "playwright": "^1.61.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
